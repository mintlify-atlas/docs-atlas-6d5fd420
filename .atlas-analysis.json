  "keyFeatures": [
    "LLVM/Clang v17-based C/C++ compiler targeting the eZ80 processor",
    "Rich library ecosystem: graphx, fontlibc, fileioc, keypadc, usbdrvce, and more",
    "Makefile-based build system with compression, archiving, and LTO support",
    "Dynamic library linking at runtime via LibLoad to minimize program size",
    "Debugging support with dbg_printf and CEmu emulator integration",
    "Cross-platform support for Windows, Linux, and macOS",
    "Image and sprite conversion via the bundled convimg tool",
    "Assembly (GAS syntax) and C/C++ interoperability"
  ],
  "publicApiSurface": [
    "graphx.h — 2D graphics: sprites, shapes, tilemaps, palettes",
    "fontlibc.h — Font rendering",
    "fileioc.h — File I/O backed by calculator AppVars",
    "keypadc.h — Keypad input",
    "lcddrvce.h — Low-level LCD driver",
    "usbdrvce.h — USB device/host driver",
    "srldrvce.h — Serial driver",
    "msddrvce.h — Mass storage driver",
    "fatdrvce.h — FAT filesystem driver",
    "libload.h — Dynamic library loader",
    "debug.h — Debugging utilities (dbg_printf)",
    "Makefile variables: NAME, ICON, DESCRIPTION, COMPRESSED, ARCHIVED, CFLAGS, CXXFLAGS, LTO"
  ]
